{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "minutesUsed": { "type": "number" },
        "avatarModel": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Session": {
      "title": "Session",
      "description": "Historical video call sessions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" },
        "transcript": { "type": "array", "items": { "type": "string" } },
        "language": { "type": "string" }
      },
      "required": ["userId", "startTime"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Call history for a specific user"
    }
  }
}
