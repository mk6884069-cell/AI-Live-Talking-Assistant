rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid is string && 
               data.email is string &&
               data.keys().hasAll(['uid', 'email']) &&
               data.keys().size() <= 10;
      }
      
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'minutesUsed', 'avatarModel']);
    }

    // Session Rules (Subcollection)
    match /users/{userId}/sessions/{sessionId} {
      function isValidSession(data) {
        return data.userId == userId &&
               data.startTime is string &&
               data.keys().hasAll(['userId', 'startTime']);
      }
      
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSession(incoming());
      allow delete: if isOwner(userId);
    }
  }
}
